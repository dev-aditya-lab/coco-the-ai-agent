PORT=4000

CORS_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/coco_agent

GROQ_API_KEY=your_groq_api_key_here
QWEN_MODEL=qwen/qwen3-32b
GPT_MODEL=openai/gpt-oss-120b


ACTION_OUTPUT_DIR=generated


PUPPETEER_HEADLESS=false
ACTION_STOP_ON_FAILURE=true
OPENCLAW_ENABLED=true
OPENCLAW_EXECUTABLE=
OPENCLAW_TIMEOUT_MS=45000
OPENCLAW_MODEL=groq/llama-3.1-8b-instant
OPENCLAW_MAX_HISTORY_ENTRIES=4
OPENCLAW_MAX_MEMORY_CHARS=1200
OPENCLAW_MAX_STEP_MESSAGE_CHARS=120
AGENT_AUTONOMOUS_MODE=true
AGENT_AUTONOMOUS_MAX_ITERATIONS=4

RESEND_API_KEY=your_resend_api_key_here

HINDSIGHT_API_KEY=your_hindsight_api_key_here
HINDSIGHT_API_ENDPOINTS=https://api.hindsight.vectorize.io
HINDSIGHT_BANK_ID=coco

TAVILY_API_KEY=your_tavily_api_key_here
